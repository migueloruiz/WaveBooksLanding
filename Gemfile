source "https://rubygems.org"
gem "github-pages", group: :jekyll_plugins
# ponytail: system Ruby is 2.6; pin ffi to the last 2.6-compatible line so
# `bundle install` resolves locally. GitHub Pages builds on its own Ruby 3.x
# and ignores this cap. Remove if the local toolchain moves to Ruby 3.x.
gem "ffi", "~> 1.15.5"
